# Copy this file to mobile/.env and fill in from your Supabase project:
#   Supabase dashboard → Project Settings → API
# These are PUBLIC by design (the anon key is safe to ship; Row-Level Security
# protects the data). Never put the service_role key or the Anthropic key here —
# those live only in Supabase Edge Function secrets.
#
# EXPO_PUBLIC_* vars are inlined into the app bundle at build time by Expo.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
